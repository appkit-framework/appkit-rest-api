    "type": "library",
    "description": "REST API utilities for the AppKit framework",
    "license": "MIT",
    "require": {
        "appkit/health": "^1.0",
        "appkit/http-router": "^1.0",
        "appkit/http-server": "^1.0"
    },
    "autoload": {
